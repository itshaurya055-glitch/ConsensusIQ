# ─────────────────────────────────────────────────────────────────
#  ConsensusIQ — Environment Variables Template
#  Copy this file to .env and fill in your real API keys.
#  NEVER commit the actual .env file.
# ─────────────────────────────────────────────────────────────────

# Groq API — free tier available at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Tavily API — web search for market news at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Google Gemini (optional, if using Gemini agents)
GOOGLE_API_KEY=your_google_api_key_here
